{
  "id": "com.guoyxu.nudge",
  "name": {
    "en": "Nudge",
    "zh-Hans": "稍后提醒"
  },
  "version": "1.1.1",
  "minAppVersion": "1.0.10",
  "main": "index.js",
  "author": {
    "name": "Guoyxu"
  },
  "description": {
    "en": "Create one-time reminders with custom minute delays and selectable alert sounds, and keep the next reminder visible on the island.",
    "zh-Hans": "按自定义分钟创建一次性提醒，可选择提示音，并在岛上持续显示最近一条提醒。"
  },
  "icon": "icon.svg",
  "license": "MIT",
  "categories": ["productivity", "utilities"],
  "permissions": ["storage", "notifications"],
  "capabilities": {
    "compact": true,
    "expanded": true,
    "fullExpanded": true,
    "minimalCompact": true,
    "backgroundRefresh": true,
    "settings": true
  },
  "refreshInterval": 1.0,
  "activationTriggers": ["manual", "timer"]
}
