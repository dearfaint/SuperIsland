{
  "id": "superisland.computer-status",
  "name": {
    "en": "Computer Status",
    "zh-Hans": "计算机状态"
  },
  "version": "1.0.0",
  "minAppVersion": "1.0.0",
  "main": "index.js",
  "author": {
    "name": "SuperIsland"
  },
  "description": {
    "en": "Modern CPU, memory, disk, SoC temperature, and fan speed status for the island.",
    "zh-Hans": "在岛中显示更现代的 CPU、内存、磁盘、芯片温度和风扇转速状态。"
  },
  "icon": "icon.svg",
  "license": "MIT",
  "categories": ["utilities", "system"],
  "permissions": ["system"],
  "capabilities": {
    "compact": true,
    "expanded": true,
    "fullExpanded": true,
    "minimalCompact": true,
    "backgroundRefresh": true,
    "settings": false
  },
  "refreshInterval": 2.0,
  "activationTriggers": ["manual", "timer"],
  "defaultEnabled": true
}
