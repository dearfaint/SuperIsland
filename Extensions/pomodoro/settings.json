          "min": 5,
          "max": 90,
          "step": 5,
          "default": 25
        },
        {
          "type": "slider",
          "key": "breakDuration",
          "label": {
            "en": "Break duration (min)",
            "zh-Hans": "休息时长（分钟）"
          },
          "min": 1,
          "max": 30,
          "step": 1,
          "default": 5
        }
      ]
    },
    {
      "title": {
        "en": "Notifications",
        "zh-Hans": "通知"
      },
      "fields": [
        {
          "type": "toggle",
          "key": "notifyOnComplete",
          "label": {
            "en": "Notify when phase ends",
            "zh-Hans": "阶段结束时通知"
          },
          "default": true
        },
        {
          "type": "toggle",
          "key": "playSound",
          "label": {
            "en": "Play notification sound",
            "zh-Hans": "播放通知声音"
