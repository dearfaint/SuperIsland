{
  "id": "superisland.pomodoro",
  "name": {
    "en": "Pomodoro Timer",
    "zh-Hans": "番茄钟"
  },
  "version": "1.0.0",
  "minAppVersion": "1.0.0",
  "main": "index.js",
  "author": {
    "name": "SuperIsland"
  },
  "description": {
    "en": "Focus timer with compact countdown and quick controls.",
    "zh-Hans": "带紧凑倒计时和快捷控制的专注计时器。"
  },
  "icon": "icon.svg",
  "license": "MIT",
  "categories": ["productivity", "timer"],
  "permissions": ["notifications", "storage"],
  "capabilities": {
    "compact": true,
    "expanded": true,
    "fullExpanded": true,
    "minimalCompact": true,
    "backgroundRefresh": true,
    "settings": true
  },
  "refreshInterval": 1.0,
  "activationTriggers": ["manual", "timer"]
}
