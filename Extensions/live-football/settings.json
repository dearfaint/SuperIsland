{
  "sections": [
    {
      "title": {
        "en": "Team",
        "zh-Hans": "球队"
      },
      "fields": [
        {
          "type": "text",
          "key": "favoriteTeam",
          "label": {
            "en": "Favorite team (FIFA code, e.g. USA, BRA, ARG)",
            "zh-Hans": "主队（FIFA 代码，如 USA、BRA、ARG）"
          },
          "placeholder": {
            "en": "USA",
            "zh-Hans": "USA"
          },
          "default": ""
        },
        {
          "type": "toggle",
          "key": "favoriteOnlyAlerts",
          "label": {
            "en": "Kickoff/full-time alerts only for my team",
            "zh-Hans": "仅为我的球队发送开球/完场提醒"
          },
          "default": false
        }
      ]
    },
    {
      "title": {
        "en": "Alerts",
        "zh-Hans": "提醒"
      },
      "fields": [
        {
          "type": "toggle",
          "key": "notifyGoals",
          "label": {
            "en": "Notify on goals",
            "zh-Hans": "进球时通知"
          },
          "default": true
        },
        {
          "type": "toggle",
          "key": "notifyKickoff",
          "label": {
            "en": "Notify at kickoff",
            "zh-Hans": "开球时通知"
          },
          "default": true
        },
        {
          "type": "toggle",
          "key": "notifyFullTime",
          "label": {
            "en": "Notify at full-time",
            "zh-Hans": "完场时通知"
          },
          "default": true
        },
        {
          "type": "toggle",
          "key": "playSound",
          "label": {
            "en": "Play notification sound",
            "zh-Hans": "播放通知声音"
          },
          "default": true
        }
      ]
    },
    {
      "title": {
        "en": "Data",
        "zh-Hans": "数据"
      },
      "fields": [
        {
          "type": "picker",
          "key": "livePoll",
          "label": {
            "en": "Live score refresh",
            "zh-Hans": "实时比分刷新"
          },
          "options": [
            { "label": { "en": "Every 15 seconds", "zh-Hans": "每 15 秒" }, "value": "15" },
            { "label": { "en": "Every 30 seconds", "zh-Hans": "每 30 秒" }, "value": "30" },
            { "label": { "en": "Every 60 seconds", "zh-Hans": "每 60 秒" }, "value": "60" }
          ],
          "default": "30"
        }
      ]
    }
  ]
}
