{
  "id": "superisland.agents-status",
  "name": {
    "en": "Agents Status",
    "zh-Hans": "代理状态"
  },
  "version": "1.6.0",
  "minAppVersion": "1.0.0",
  "main": "index.js",
  "author": { "name": "yanlin" },
  "description": {
    "en": "Live Claude Code and Codex CLI session status (Working / Waiting / Idle / Error) as a 5x5 pixel animation, with multi-session focus support.",
    "zh-Hans": "以 5x5 像素动画实时显示 Claude Code 和 Codex CLI 会话状态（工作中 / 等待 / 空闲 / 错误），支持多会话聚焦。"
  },
  "icon": "icon.svg",
  "license": "MIT",
  "categories": ["productivity", "dev-tools"],
  "permissions": ["network", "storage", "notifications"],
  "capabilities": {
    "compact": true,
    "expanded": true,
    "fullExpanded": true,
    "minimalCompact": true,
    "backgroundRefresh": true,
    "settings": true
  },
  "refreshInterval": 1.0,
  "activationTriggers": ["manual", "timer"]
}
